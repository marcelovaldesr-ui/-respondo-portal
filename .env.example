# === Supabase (misma base del motor 2.0, schema ed_) ===
# Se usan SOLO en el servidor. La service role NUNCA se expone al navegador.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cliente Supabase para el navegador (Auth magic link — se agrega en el Paso 2)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# === Gemini (para "Probar ahora" — se usa en el Paso 5) ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# URL pública del portal (para los enlaces del magic link)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === WhatsApp Cloud API — Opción B (número de PRUEBA de Meta en desarrollo) ===
# Token que TÚ inventas y pones igual en la config del webhook de la app de Meta.
WHATSAPP_VERIFY_TOKEN=un-string-secreto-que-tu-elijas
# Del panel de Meta (WhatsApp > API Setup): token temporal y phone_number_id del número de prueba.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Cliente al que se le asignan los mensajes del número de prueba (ej: Impresora Color = 33333333-3333-3333-3333-333333333333)
WHATSAPP_DEV_CLIENTE_ID=

# === Evolution API — Opción A (WhatsApp no oficial por QR) ===
EVOLUTION_API_URL=https://tu-evolution.up.railway.app
EVOLUTION_API_KEY=            # AUTHENTICATION_API_KEY del servicio Evolution en Railway
EVOLUTION_WEBHOOK_SECRET=     # string secreto; se manda en el webhook como ?k=...
